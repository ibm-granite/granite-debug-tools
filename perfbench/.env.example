# Optional: watsonx.ai credentials (for the LangChain client example)
WATSONX_APIKEY=your-api-key
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-project-id

# Optional: LLM provider for the LangChain client (ollama or watsonx)
LLM_PROVIDER=ollama

# Optional: server log level (DEBUG, INFO, WARNING, ERROR)
MCP_LOG_LEVEL=INFO
